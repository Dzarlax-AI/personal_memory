MEMORY_DOMAIN=example.com
API_KEY=replace_with_openssl_rand_hex_32
# Development-only escape hatch. Keep false in every deployed environment.
ALLOW_INSECURE_AUTH=false
EMBED_MODEL=intfloat/multilingual-e5-small
EMBED_MODEL_REVISION=614241f622f53c4eeff9890bdc4f31cfecc418b3
# One-shot bootstrap only for verified existing collections that predate
# embedding identity metadata. Keep false during normal operation. It never
# overrides a stored identity mismatch.
ADOPT_EXISTING_EMBEDDING_IDENTITY=false

# Username stored as metadata in facts (any string, e.g. your name)
MEMORY_USER=your_username

# Related-fact candidates use cosine similarity; this is not a conflict score.
RELATED_FACT_LOW=0.60
# Legacy compatibility for one deprecation window. RELATED_FACT_LOW wins if both are set.
# CONTRADICTION_LOW=0.60

# Optional services (set to true to enable)
ENABLE_TODOIST=false
ENABLE_VIZ=false
# Required only when ENABLE_VIZ=true. Traefik overwrites the trusted header
# with this independent secret after successful Authentik ForwardAuth.
VIZ_PROXY_SECRET=

# Optional ChatGPT Apps / connector OAuth support for the /memory MCP endpoint.
# Keep API_KEY configured for existing MCP clients; OAuth is additive.
OAUTH_ENABLED=false
OAUTH_ISSUER=https://auth.example.com/application/o/personal-memory
OAUTH_RESOURCE=https://mcp.example.com
OAUTH_AUDIENCE=https://mcp.example.com
OAUTH_SCOPES=memory:mcp
# Optional. If empty, the server discovers jwks_uri from OAUTH_ISSUER/.well-known/openid-configuration.
OAUTH_JWKS_URL=
# Optional. Defaults to OAUTH_ISSUER when empty.
OAUTH_AUTHORIZATION_SERVERS=
OAUTH_RESOURCE_DOCUMENTATION=

# Todoist API token (only needed when ENABLE_TODOIST=true)
# Get from https://app.todoist.com/app/settings/integrations/developer
TODOIST_TOKEN=your_todoist_api_token

# Backup settings
KEEP_SNAPSHOTS=7          # number of snapshots to keep
BACKUP_INTERVAL_HOURS=24  # how often to create a snapshot

# RAG (hierarchical document search) — optional
ENABLE_RAG=false
RAG_DOCUMENTS_DIR=/root/documents/personal
RAG_CHUNK_MAX_BYTES=1500
RAG_FOLDER_TOP_K=3
RAG_FOLDER_THRESHOLD=0.50
RAG_COLLECTION_CHUNKS=doc_chunks
RAG_COLLECTION_FOLDERS=doc_folders
# Auto-rescan: how often the server re-indexes the docs dir in a background
# goroutine. 0 disables — run manually via the MCP tool or cmd/indexer.
RAG_REINDEX_INTERVAL_MINUTES=0
